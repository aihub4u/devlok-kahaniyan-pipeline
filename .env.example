# Server-side login (Basic Auth) - required, the app blocks access without these set
ADMIN_USERNAME=raj
ADMIN_PASSWORD=change_this_to_something_strong

# Sarvam AI
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_TTS_MODEL=bulbul:v3
# bulbul:v3 valid speakers: shubh (default), aditya, ritu, priya, neha, rahul, pooja,
# rohan, simran, kavya, amit, dev, ishita, shreya, ratan, varun, manan, sumit, roopa,
# kabir, aayan, ashutosh, advait, anand, tanya, tarun, sunny, mani, gokul, vijay,
# shruti, suhani, mohit, kavitha, rehan, soham, rupali
# bulbul:v2 speakers are a DIFFERENT, non-overlapping list - don't mix versions/speakers.
# Full docs: https://docs.sarvam.ai/api-reference-docs/text-to-speech/convert
SARVAM_VOICE=ritu
SARVAM_LANGUAGE_CODE=hi-IN

# Replicate - https://replicate.com/account/api-tokens
# Only used for STILL IMAGES now - no AI video generation model, to keep cost low.
# Motion comes from FFmpeg's Ken Burns pan/zoom effect (free, local processing) instead.
REPLICATE_API_TOKEN=your_replicate_token_here
REPLICATE_IMAGE_MODEL=black-forest-labs/flux-schnell

# Output frame size for the Ken Burns video (portrait 9:16, matches Shorts/Reels).
# Kept small (540x960) by default - Render's free tier caps memory at 512MB, and
# FFmpeg's zoompan filter is memory-hungry. If you're still hitting "ran out of
# memory" errors in Render's event log after this, the real fix is upgrading to
# Render's Starter plan (or higher) rather than shrinking resolution further -
# 512MB is genuinely tight for video processing regardless of these settings.
# Use 960x540 instead if you're generating 16:9 long-form landscape content.
FRAME_WIDTH=540
FRAME_HEIGHT=960
IMAGE_ASPECT_RATIO=9:16

# --- Cost dashboard rates ---
# Not fetched automatically - fill in your actual current rates so the Cost Dashboard
# tab can estimate spend. Leave a value at 0 to disable that specific estimate.
#   Sarvam pricing: https://www.sarvam.ai/pricing (or your invoice/dashboard)
#   Replicate image pricing: check replicate.com/black-forest-labs/flux-schnell
#   (bills a flat rate per image, not per second - Flux Schnell is typically a fraction
#    of a cent per image, but confirm the current number on the model's page)
SARVAM_COST_PER_1000_CHARS=0
REPLICATE_IMAGE_COST_PER_IMAGE=0
COST_CURRENCY=USD

# Output storage
OUTPUT_DIR=./output

# Optional: auto-upload later (leave blank for now, you review manually first)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
