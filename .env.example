# Server-side login (Basic Auth) - required, the app blocks access without these set
ADMIN_USERNAME=raj
ADMIN_PASSWORD=change_this_to_something_strong

# Sarvam AI
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_TTS_MODEL=bulbul:v2
SARVAM_VOICE=meera
SARVAM_LANGUAGE_CODE=hi-IN

# Replicate - https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=your_replicate_token_here

# Replicate model versions (check replicate.com/<model> for the latest version hash)
REPLICATE_IMAGE_MODEL=black-forest-labs/flux-schnell
REPLICATE_VIDEO_MODEL=wan-video/wan-2.5-i2v-fast

# --- Cost dashboard rates ---
# These are NOT fetched automatically - Replicate/Sarvam don't return live pricing in their
# API responses. Check your actual dashboards below and fill in current rates so the Cost
# Dashboard tab can estimate spend per episode. Leave at 0 to disable that estimate.
#   Sarvam pricing: https://www.sarvam.ai/pricing (or your invoice/dashboard)
#   Replicate pricing: check each model's page, e.g. replicate.com/black-forest-labs/flux-schnell
#                        and replicate.com/wan-video/wan-2.5-i2v-fast
SARVAM_COST_PER_1000_CHARS=0
REPLICATE_IMAGE_COST_PER_SEC=0
REPLICATE_VIDEO_COST_PER_SEC=0
COST_CURRENCY=INR

# Output storage
OUTPUT_DIR=./output

# Optional: auto-upload later (leave blank for now, you review manually first)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
